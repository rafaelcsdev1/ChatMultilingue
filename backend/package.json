    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.22",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.5",
    "prisma": "^5.15.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
